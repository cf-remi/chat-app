# Cloudflare Account ID — found on the dashboard overview page
CF_ACCOUNT_ID=your-account-id

# Cloudflare API Token — create one with Realtime / Realtime Admin permissions
CF_API_TOKEN=your-bearer-token

# RealtimeKit App ID — created in Realtime → RealtimeKit → Create App
CF_APP_ID=your-realtimekit-app-id

# Preset name — must exist in your RealtimeKit app (e.g. "group_call_host")
RTK_PRESET_NAME=group_call_host

PORT=3001
